# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key-here

# Stripe Price IDs (create these in Stripe Dashboard → Products)
VITE_STRIPE_PRICE_USD=price_xxx
VITE_STRIPE_PRICE_GBP=price_xxx
VITE_STRIPE_PRICE_EUR=price_xxx
VITE_STRIPE_PRICE_CAD=price_xxx
VITE_STRIPE_PRICE_AUD=price_xxx

# Development only — set to true to use mock data without Supabase
VITE_MOCK_AUTH=false

# ─── Analytics ────────────────────────────────────────────────────────────────
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your-posthog-token-here
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
